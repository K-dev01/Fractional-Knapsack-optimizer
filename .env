# ============================================
# Fractional Knapsack Optimizer - Environment Configuration
# ============================================

# Application Environment
VITE_APP_NAME=Fractional Knapsack Optimizer
VITE_APP_VERSION=1.0.0
VITE_ENV=development

# Feature Flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_RANDOM_DATA=true
VITE_ENABLE_SOUND_EFFECTS=false
VITE_ENABLE_ANALYTICS=false

# Default Settings
VITE_DEFAULT_CAPACITY=50
VITE_DEFAULT_SPEED=1
VITE_DEFAULT_THEME=dark

# Algorithm Settings
VITE_MAX_ITEMS=100
VITE_MIN_WEIGHT=1
VITE_MAX_WEIGHT=100
VITE_MIN_VALUE=1
VITE_MAX_VALUE=1000

# Badge Thresholds
VITE_BADGE_PERFECT_THRESHOLD=95
VITE_BADGE_MASTER_THRESHOLD=80
VITE_BADGE_EXPERT_THRESHOLD=70
VITE_BADGE_PACK_THRESHOLD=5

# Animation Settings
VITE_ANIMATION_DURATION=500
VITE_STEP_DELAY=2000
VITE_ENABLE_ANIMATIONS=true

# API Endpoints (for future backend integration)
VITE_API_BASE_URL=http://localhost:5173
VITE_API_TIMEOUT=5000

# Debug Mode
VITE_DEBUG_MODE=false
VITE_LOG_ALGORITHM_STEPS=false

# ============================================
# Notes:
# - VITE_ prefix makes variables accessible in browser via import.meta.env
# - Restart dev server after changing .env file
# - Create .env.local for local overrides (not committed to git)
# ============================================
